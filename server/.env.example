# =============================================================================
# OWLmon 서버 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사 후 값을 수정하세요
#   cp .env.example .env
# =============================================================================

# --- 필수 설정 ---

# JWT 인증 시크릿 (최소 32자 랜덤 문자열 권장)
# 미설정 시 서버가 임시 시크릿을 생성하며 재시작마다 세션이 초기화됩니다
OWLMON_JWT_SECRET=change-me-to-random-hex-string

# 관리자 비밀번호 해시 (bcrypt)
# 생성 방법: cd server && go run ./cmd/hashpw admin
# 주의: bcrypt 해시에 $ 기호가 포함되므로 반드시 작은따옴표로 감싸세요
OWLMON_PASSWORD_HASH='$2a$10$여기에_해시를_붙여넣으세요'

# --- PostgreSQL ---

# PostgreSQL 연결 문자열 (docker-compose.yml의 postgres 서비스 기준)
# 미설정 시 파일 기반 저장으로 폴백 (알림 히스토리 제한됨)
POSTGRES_DSN=postgres://owlmon:owlmon@localhost:5433/owlmon

# --- 선택 설정 ---

# 관리자 사용자명 (기본값: admin)
# OWLMON_USERNAME=admin

# 서버 리슨 주소 (기본값: :8080)
# OWLMON_LISTEN=:8080

# Prometheus URL (기본값: http://localhost:9090)
# OWLMON_PROMETHEUS_URL=http://localhost:9090

# --- 이메일 알림 (선택) ---

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@email.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=owlmon@your-domain.com
# SMTP_TO=admin@your-domain.com
